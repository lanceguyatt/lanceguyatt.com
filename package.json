{
  "name": "lanceguyatt",
  "version": "1.0.0",
  "description": "Personal site built with Contentful, ReactJS, GatsbyJS, GraphQL, and Styled Components. Inspired by Amiga Workbench 2.0.",
  "keywords": [
    "contentful",
    "react",
    "gatsby",
    "graphql",
    "styled-components",
    "amiga"
  ],
  "homepage": "https://github.com/lanceguyatt/lanceguyatt",
  "license": "MIT",
  "author": "Lance Guyatt <lance@lanceguyatt.com> (https://lanceguyatt.com/)",
  "repository": {
    "type": "git",
    "url": "https://github.com/lanceguyatt/lanceguyatt.git"
  },
  "scripts": {
    "build": "gatsby build",
    "dev": "gatsby develop",
    "clean": "rm -rf public .cache",
    "format": "prettier --write \"./**/*.js\" \"./**/*.jsx\"",
    "diff": "prettier --list-different \"**/*.js\" \"**/*.jsx\"",
    "lint:css": "stylelint \"./src/**/*.js\"",
    "lint": "eslint . --ext .js,.jsx --ignore-path .gitignore",
    "eslint-check": "eslint --print-config .eslintrc | eslint-config-prettier-check",
    "offline": "GATSBY_CONTENTFUL_OFFLINE=true yarn run dev",
    "deploy": "npm run clean && npm run build && npm run build-storybook && netlify deploy",
    "deploy:prod": "npm run clean && npm run build && netlify deploy --prod",
    "storybook": "start-storybook -s ./static -p 6006",
    "build-storybook": "build-storybook -s ./static -o ./public/storybook"
  },
  "dependencies": {
    "@emotion/core": "^10.0.27",
    "@mdx-js/mdx": "^1.5.4",
    "@mdx-js/react": "^1.5.4",
    "@rebass/components": "^4.0.0-1",
    "@styled-system/css": "^5.1.4",
    "@theme-ui/components": "^0.2.50",
    "dotenv": "^8.2.0",
    "eslint-plugin-react-hooks": "^2.3.0",
    "gatsby": "^2.18.22",
    "gatsby-image": "^2.2.38",
    "gatsby-plugin-canonical-urls": "^2.1.19",
    "gatsby-plugin-google-analytics": "^2.1.33",
    "gatsby-plugin-manifest": "^2.2.37",
    "gatsby-plugin-mdx": "^1.0.67",
    "gatsby-plugin-nprogress": "^2.1.18",
    "gatsby-plugin-offline": "^3.0.32",
    "gatsby-plugin-react-helmet": "^3.1.21",
    "gatsby-plugin-sitemap": "^2.2.25",
    "gatsby-plugin-styled-components": "^3.1.17",
    "gatsby-plugin-theme-ui": "^0.2.53",
    "gatsby-remark-prismjs": "^3.3.30",
    "gatsby-source-contentful": "^2.1.76",
    "polished": "^3.4.2",
    "prismjs": "^1.19.0",
    "prop-types": "^15.7.2",
    "react": "^16.12.0",
    "react-css-transition": "^0.7.4",
    "react-dom": "^16.12.0",
    "react-helmet": "^5.2.1",
    "react-modal": "^3.11.1",
    "recompose": "^0.30.0",
    "styled-components": "^4.4.1",
    "styled-system": "^5.1.4",
    "system-components": "^3.0.3",
    "theme-ui": "^0.2.52"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^5.3.4",
    "@storybook/addon-actions": "^5.3.4",
    "@storybook/addon-console": "^1.2.1",
    "@storybook/addon-docs": "^5.3.4",
    "@storybook/addon-links": "^5.3.4",
    "@storybook/addon-storysource": "^5.3.4",
    "@storybook/addon-viewport": "^5.3.4",
    "@storybook/addons": "^5.3.4",
    "@storybook/react": "^5.3.4",
    "babel-eslint": "^10.0.3",
    "eslint": "^6.8.0",
    "eslint-config-airbnb": "^18.0.1",
    "eslint-config-prettier": "^6.9.0",
    "eslint-plugin-compat": "^3.3.0",
    "eslint-plugin-import": "^2.20.0",
    "eslint-plugin-jsx-a11y": "^6.2.3",
    "eslint-plugin-prettier": "^3.1.2",
    "eslint-plugin-react": "^7.18.0",
    "prettier": "^1.19.1",
    "stylelint": "^13.0.0",
    "stylelint-config-recommended": "^3.0.0",
    "stylelint-config-styled-components": "^0.1.1",
    "stylelint-processor-styled-components": "^1.9.0"
  },
  "private": true,
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "IE 11"
  ]
}
