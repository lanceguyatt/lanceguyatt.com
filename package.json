{
  "name": "lanceguyatt",
  "version": "1.0.0",
  "description": "Personal site built with Contentful, ReactJS, GatsbyJS, GraphQL, and Styled Components. Inspired by Amiga Workbench 2.0.",
  "keywords": [
    "contentful",
    "react",
    "gatsby",
    "graphql",
    "styled-components",
    "amiga"
  ],
  "homepage": "https://github.com/lanceguyatt/lanceguyatt",
  "license": "MIT",
  "author": "Lance Guyatt <lance@lanceguyatt.com> (https://lanceguyatt.com/)",
  "repository": {
    "type": "git",
    "url": "https://github.com/lanceguyatt/lanceguyatt.git"
  },
  "scripts": {
    "build": "gatsby build",
    "dev": "gatsby develop",
    "clean": "gatsby clean",
    "format": "prettier --write \"./**/*.js\" \"./**/*.jsx\"",
    "diff": "prettier --list-different \"**/*.js\" \"**/*.jsx\"",
    "lint:css": "stylelint \"./src/**/*.js\"",
    "lint": "eslint . --ext .js,.jsx --ignore-path .gitignore",
    "eslint-check": "eslint --print-config .eslintrc | eslint-config-prettier-check",
    "offline": "GATSBY_CONTENTFUL_OFFLINE=true yarn run dev",
    "deploy": "npm run clean && npm run build && npm run build-storybook && netlify deploy",
    "deploy:prod": "npm run clean && npm run build && netlify deploy --prod",
    "storybook": "start-storybook -s ./static -p 6006",
    "build-storybook": "build-storybook -s ./static -o ./public/storybook"
  },
  "dependencies": {
    "@emotion/react": "^11.0.0",
    "@mdx-js/mdx": "^1.6.21",
    "@mdx-js/react": "^1.6.21",
    "dotenv": "^8.2.0",
    "eslint-plugin-react-hooks": "^4.2.0",
    "gatsby": "^2.26.1",
    "gatsby-image": "^2.5.0",
    "gatsby-plugin-canonical-urls": "^2.4.0",
    "gatsby-plugin-google-analytics": "^2.5.0",
    "gatsby-plugin-manifest": "^2.6.0",
    "gatsby-plugin-mdx": "^1.4.0",
    "gatsby-plugin-nprogress": "^2.4.0",
    "gatsby-plugin-react-helmet": "^3.4.0",
    "gatsby-plugin-sitemap": "^2.6.0",
    "gatsby-plugin-theme-ui": "^0.3.3",
    "gatsby-remark-prismjs": "^3.7.0",
    "gatsby-source-contentful": "^4.0.0",
    "levenary": "^1.1.1",
    "prismjs": "^1.22.0",
    "prop-types": "^15.7.2",
    "react": "^17.0.1",
    "react-css-transition": "^0.7.4",
    "react-dom": "^17.0.1",
    "react-helmet": "^6.1.0",
    "react-modal": "^3.11.2",
    "recompose": "^0.30.0",
    "theme-ui": "^0.3.3"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^6.0.28",
    "@storybook/addon-actions": "^6.0.28",
    "@storybook/addon-essentials": "^6.0.28",
    "@storybook/addon-links": "^6.0.28",
    "@storybook/react": "^6.0.28",
    "babel-eslint": "^10.1.0",
    "eslint": "^7.13.0",
    "eslint-config-airbnb": "^18.2.1",
    "eslint-config-prettier": "^6.15.0",
    "eslint-plugin-compat": "^3.8.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-prettier": "^3.1.4",
    "eslint-plugin-react": "^7.21.5",
    "prettier": "^2.1.2",
    "stylelint": "^13.7.2",
    "stylelint-config-recommended": "^3.0.0"
  },
  "private": true,
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "IE 11"
  ]
}
